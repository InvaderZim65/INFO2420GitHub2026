</head>
<body onload="preloadImages()">
    
    <header>
        <div class="header-left">
            <img src="Images/Logo.jpg" alt="Extreme Honeymoons Logo" id="logoImg" onmouseover="logoHover()" onmouseout="logoNormal()">
            <img src="Images/ExtremeHoneymoonsBanner.jpg" alt="Extreme Honeymoons Banner" class="banner">
        </div>

        <nav>
            <a href="Home.html">Home</a>
            <a href="AboutUs.html">About Us</a>
            <a href="Tributes.html">Tributes</a>
            <a href="Survey.html">Survey</a>
            <a href="Links.html">Favorites</a>
        </nav>
    </header>

    <section>
        <article>
            <h2>Main Page Content</h2>
            <p>This is the editable region where page content goes.</p>
            
            </article>
    </section>

    <footer>
        <p>Contact the Webmaster: <a href="mailto:your.email@example.com">your.email@example.com</a></p>
        <p>This web site has been created solely for educational purposes.</p>
        
        <p style="margin-top: 20px;">
            <a href="http://validator.w3.org/check?uri=referer" target="_blank">
                <img src="https://www.w3.org/html/logo/badge/html5-badge-h-solo.png" width="63" height="64" alt="HTML5 Powered" title="HTML5 Validated">
            </a>
        </p>
    </footer>

</body>
</html>